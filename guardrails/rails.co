# ── Input/Output Rails (self-check, LLM-based) ────────────────────────────────
#
# Lưu ý kỹ thuật: bản gốc của file này dùng pattern "user ask X / bot refuse X"
# (canonical-form intent matching qua flows riêng cho jailbreak/off-topic/pii).
# Khi test với nemoguardrails 0.22 (Colang 1.0), các flow này không bao giờ
# thực sự generate user intent khi được gọi như input rail (0 LLM/embedding
# calls, "check jailbreak" luôn match đầu tiên bất kể nội dung) — một vấn đề
# tương thích phiên bản, không liên quan tới việc đổi sang Gemini.
# → Thay bằng pattern "self check input/output" chính thức của NeMo Guardrails
#   (execute self_check_input / self_check_output, xem guardrails/config.yml
#   phần `prompts:`), vẫn dùng 1 LLM call để phân loại jailbreak + off-topic +
#   pii request + sensitive output trong cùng 1 prompt.

define bot refuse to respond
  "Xin lỗi, tôi không thể thực hiện yêu cầu này. Tôi chỉ có thể trả lời các câu hỏi về chính sách nhân sự công ty."

define flow self check input
  $allowed = execute self_check_input

  if not $allowed
    bot refuse to respond
    stop

define flow self check output
  $allowed = execute self_check_output

  if not $allowed
    bot refuse to respond
    stop


# ── HR Policy Flows (allowed topics) ──────────────────────────────────────────

define user ask about hr policy
  "nghỉ phép"
  "ngày phép"
  "phép năm"
  "bảo hiểm"
  "lương"
  "thưởng"
  "tạm ứng"
  "công tác"
  "thử việc"
  "đào tạo"
  "VPN"
  "mật khẩu"
  "WFH"
  "làm việc từ xa"
  "phụ cấp"
  "mentor"

define flow self check facts
  $facts = execute check_facts
  if not $facts.accurate
    bot say "Lưu ý: Câu trả lời trên có thể không chính xác. Vui lòng xác nhận với phòng Nhân sự."
